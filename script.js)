/* =============================================================================
DETECTIVE ACADEMY — EDUCATIONAL PLATFORM LOGIC
============================================================================= */

document.addEventListener('DOMContentLoaded', function() {
    console.log('■ DETECTIVE ACADEMY READY ■');

    /* ---------------------------------------------------------------------
       THEME TOGGLE
       --------------------------------------------------------------------- */
    var themeToggle = document.getElementById('theme-toggle');
    var themeIcon = themeToggle.querySelector('.theme-icon');
    var themeText = themeToggle.querySelector('.theme-text');
    var body = document.body;

    // Load saved theme or default to dark
    var savedTheme = localStorage.getItem('detective-academy-theme') || 'dark';
    if (savedTheme === 'light') {
        body.classList.add('light-theme');
        body.classList.remove('dark-theme');
        themeIcon.textContent = '◑';
        themeText.textContent = 'ВО ТЬМУ';
    } else {
        body.classList.add('dark-theme');
        body.classList.remove('light-theme');
        themeIcon.textContent = '◐';
        themeText.textContent = 'НА СВЕТ';
    }

    themeToggle.addEventListener('click', function() {
        if (body.classList.contains('dark-theme')) {
            body.classList.remove('dark-theme');
            body.classList.add('light-theme');
            themeIcon.textContent = '◑';
            themeText.textContent = 'ВО ТЬМУ';
            localStorage.setItem('detective-academy-theme', 'light');
        } else {
            body.classList.remove('light-theme');
            body.classList.add('dark-theme');
            themeIcon.textContent = '◐';
            themeText.textContent = 'НА СВЕТ';
            localStorage.setItem('detective-academy-theme', 'dark');
        }
    });

    /* ---------------------------------------------------------------------
       FLASHCARDS FLIP FUNCTIONALITY
       --------------------------------------------------------------------- */
    var flashcards = document.querySelectorAll('.flashcard');

    flashcards.forEach(function(card) {
        card.addEventListener('click', function() {
            this.classList.toggle('flipped');
        });

        // Keyboard accessibility
        card.setAttribute('tabindex', '0');
        card.setAttribute('role', 'button');
        card.setAttribute('aria-label', 'Флеш-карточка. Нажмите для переворота');

        card.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                this.classList.toggle('flipped');
            }
        });
    });

    /* ---------------------------------------------------------------------
       ASSIGNMENT CHECK FUNCTIONALITY
       --------------------------------------------------------------------- */
    var checkButtons = document.querySelectorAll('.check-btn');

    checkButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
            var input = this.previousElementSibling;
            var userAnswer = input.value.trim().toLowerCase();
            var correctAnswer = input.dataset.answer.toLowerCase();

            if (userAnswer === correctAnswer) {
                input.classList.add('correct');
                input.classList.remove('incorrect');
                btn.classList.add('checked-correct');
                btn.classList.remove('checked-incorrect');
                btn.textContent = '✓';
                showFeedback(true, 'Правильно. Дело закрыто. 🎯');
            } else {
                input.classList.add('incorrect');
                input.classList.remove('correct');
                btn.classList.add('checked-incorrect');
                btn.classList.remove('checked-correct');
                btn.textContent = '✗';
                showFeedback(false, 'Ошибка. Попробуйте снова. Правильный ответ: ' + input.dataset.answer);
            }
        });
    });

    /* ---------------------------------------------------------------------
       MULTIPLE CHOICE FUNCTIONALITY
       --------------------------------------------------------------------- */
    var radioButtons = document.querySelectorAll('input[type="radio"]');

    radioButtons.forEach(function(radio) {
        radio.addEventListener('change', function() {
            var parent = this.closest('.assignment-item');
            
            if (this.value === 'correct') {
                showFeedbackInParent(parent, true, 'Верно. Отличная работа. ✓');
            } else {
                showFeedbackInParent(parent, false, 'Неверно. Изучите материал ещё раз.');
            }
        });
    });

    /* ---------------------------------------------------------------------
       FEEDBACK HELPER FUNCTIONS
       --------------------------------------------------------------------- */
    function showFeedback(isSuccess, message) {
        // Remove existing feedback
        var existing = document.querySelector('.assignment-feedback');
        if (existing) {
            existing.remove();
        }

        // Create new feedback
        var feedback = document.createElement('div');
        feedback.className = 'assignment-feedback ' + (isSuccess ? 'success' : 'error');
        feedback.style.display = 'flex';
        feedback.innerHTML = 
            '<span class="feedback-icon">' + (isSuccess ? '✓' : '✗') + '</span>' +
            '<span class="feedback-text">' + message + '</span>';

        // Insert after the last assignment-item
        var lastItem = document.querySelector('.assignment-item:last-child');
        if (lastItem) {
            lastItem.parentNode.insertBefore(feedback, lastItem.nextSibling);
        }

        // Auto-hide after 5 seconds
        setTimeout(function() {
            feedback.style.opacity = '0';
            feedback.style.transition = 'opacity 0.3s ease';
            setTimeout(function() {
                feedback.remove();
            }, 300);
        }, 5000);
    }

    function showFeedbackInParent(parent, isSuccess, message) {
        var feedback = parent.querySelector('.assignment-feedback');

        if (!feedback) {
            feedback = document.createElement('div');
            feedback.className = 'assignment-feedback';
            parent.appendChild(feedback);
        }

        feedback.className = 'assignment-feedback ' + (isSuccess ? 'success' : 'error');
        feedback.style.display = 'flex';
        feedback.innerHTML = 
            '<span class="feedback-icon">' + (isSuccess ? '✓' : '✗') + '</span>' +
            '<span class="feedback-text">' + message + '</span>';
    }

    /* ---------------------------------------------------------------------
       SMOOTH SCROLL FOR ANCHORS
       --------------------------------------------------------------------- */
    document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            var targetId = this.getAttribute('href');
            if (targetId === '#') return;

            var target = document.querySelector(targetId);
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });
});
